# Stow ignore file - files matching these patterns won't be symlinked
# Uses Perl regex syntax

# Repository metadata and documentation
^/CLAUDE\.md$
^/AGENTS\.md$
^/README\.md$
^/README$
^/LICENSE$

# Installation and scripts
^/install\.sh$
^/setup-vertex-credentials\.sh$

# Documentation
^/docs

# Version control
^/\.git
^/\.gitignore$
^/\.gitmodules$

# Editor and IDE
^/\.idea
^/\.vscode
^/\.DS_Store$
settings\.local\.json

# Repo-scoped Claude Code config (skills, commands) lives at .claude/
# at the repo root because Claude reads it from cwd. NOT a dotfile to
# install into ~/.claude.
^/\.claude$


# Stow-related
^/\.stow-.*