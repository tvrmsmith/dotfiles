# Stow ignore file - files matching these patterns won't be symlinked
# Uses Perl regex syntax

# Repository metadata and documentation
^/CLAUDE\.md$
^/AGENTS\.md$
^/README\.md$
^/README$
^/LICENSE$

# Installation and scripts
^/install\.sh$
^/setup-vertex-credentials\.sh$

# Documentation
^/docs

# Version control
^/\.git
^/\.gitignore$
^/\.gitmodules$

# Editor and IDE
^/\.idea
^/\.vscode
^/\.DS_Store$
settings\.local\.json

# Stow-related
^/\.stow-.*


# dot-warp is managed by setup_warp() in install.sh, not by stow.
# Warp writes runtime data into ~/.warp (worktrees, language servers,
# generated tab configs); folding ~/.warp -> dot-warp/ would route
# those writes into this repo.
^/dot-warp$