[gpg]
	format = ssh
[gpg "ssh"]
	program = /Users/trevor.smith/.local/bin/op-ssh-sign
	allowedSignersFile = ~/.ssh/allowed_signers
[commit]
	gpgsign = true
[user]
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDCVsIviMhYuKXaXPDnU47cBmR3h2eiKq59GmS+uFvPe
	name = Trevor Smith
	email = trevor.smith@wellsky.com
[alias]
	up = pull --rebase
[merge "ours"]
	driver = true
[core]
	pager = delta
[diff]
  # Neovim diff tool
  tool = nvimdiff
[delta]
# minus-style                   = syntax "#4b2a3d"
# minus-non-emph-style          = syntax "#4b2a3d"
# minus-emph-style              = syntax "#6b2e43"
# minus-empty-line-marker-style = syntax "#4b2a3d"
# line-numbers-minus-style      = "#e26a75"
# plus-style                    = syntax "#2a4556"
# plus-non-emph-style           = syntax "#2a4556"
# plus-emph-style               = syntax "#305f6f"
# plus-empty-line-marker-style  = syntax "#2a4556"
# line-numbers-plus-style       = "#b8db87"
# line-numbers-zero-style       = "#3b4261"
	navigate = true
[interactive]
	diffFilter = delta --color-only
[merge]
	conflictStyle = zdiff3
[pull]
	rebase = true

# Sandbox overrides (no-op on host if file doesn't exist)
[include]
	path = ~/.gitconfig.sandbox

# Personal repos under ~/dev/personal/ get personal identity and sandbox signing key
[includeIf "gitdir:~/dev/personal/"]
	path = ~/.gitconfig-personal
[includeIf "gitdir:~/dev/personal/"]
	path = ~/.gitconfig.sandbox-personal

# Personal repos cloned outside ~/dev/personal/ (e.g. this dotfiles repo lives
# at ~/dev/dotfiles) — matched by remote instead of path so identity follows
# the repo regardless of where it's checked out.
[includeIf "hasconfig:remote.*.url:git@github.com:tvrmsmith/**"]
	path = ~/.gitconfig-personal
[includeIf "hasconfig:remote.*.url:git@github.com:tvrmsmith/**"]
	path = ~/.gitconfig.sandbox-personal

# Machine-local identity override — e.g. on a personal-only machine, set
# [user] here to make the personal identity the default everywhere instead
# of relying on the includeIf rules above. No-op if file doesn't exist.
[include]
	path = ~/.gitconfig.local
