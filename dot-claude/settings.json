  "hooks": {
    "PreToolUse": [],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p \"$HOME/.claude/logs\"; lavish-axi >>\"$HOME/.claude/logs/lavish-hook.log\" 2>&1 || true",
            "timeout": 20
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "command -v bd >/dev/null 2>&1 && bd prime --mcp || true"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "command -v bd >/dev/null 2>&1 && bd prime --mcp || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/caveman-reminder.sh"
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "mise exec node@25 -- claude-powerline --theme=tokyo-night --style=powerline"
  },
