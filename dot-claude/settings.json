    "deny": [
      "EnterPlanMode",
      "ExitPlanMode",
      "NotebookEdit",
      "CronCreate",
      "CronDelete",
      "CronList",
      "EnterWorktree",
      "ExitWorktree",
      "SendMessage",
      "Bash(sudo *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(chmod -R 777 *)",
      "Bash(mkfs*)",
      "Bash(dd if=*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(npm -g *)",
      "Bash(npm install -g *)",
      "Bash(pip install --user *)"
