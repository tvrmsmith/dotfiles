{
  "skillListingMaxDescChars": 500,
  "skillListingBudgetFraction": 0.02,
  "env": {
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_SONNET_MODEL_SUPPORTS": "effort,thinking,adaptive_thinking,interleaved_thinking,web_search",
    "ANTHROPIC_VERTEX_PROJECT_ID": "consolo-dev-vertex-wsky",
    "CLAUDE_CODE_USE_VERTEX": "1",
    "CLOUD_ML_REGION": "global",
    "SUPERSET_DEBUG_HOOKS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(docker build:*)",
      "Bash(git add:*)",
      "Bash(grep:*)",
      "Bash(docker run:*)",
      "Bash(docker logs:*)",
      "Bash(curl:*)",
      "Bash(docker stop:*)",
      "Bash(git *)",
      "Bash(npm test*)",
      "Bash(npm run *)",
      "Bash(cargo test*)",
      "Bash(cargo build*)",
      "Bash(cargo clippy*)",
      "Bash(cargo fmt*)",
      "Bash(node --test*)",
      "Bash(gh *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(which *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(chmod -R 777 *)",
      "Bash(mkfs*)",
      "Bash(dd if=*)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)",
      "Bash(npm -g *)",
      "Bash(npm install -g *)",
      "Bash(pip install --user *)"
    ],
    "defaultMode": "default"
  },
  "model": "claude-opus-4-6",
  "skillOverrides": {
    "claude-code-setup:claude-automation-recommender": "user-invocable-only",
    "shared:pr-comments-analyzer": "user-invocable-only",
    "claude-md-management:claude-md-improver": "user-invocable-only",
    "shared:skill-builder": "off",
    "superpowers:writing-skills": "off",
    "caveman:caveman-compress": "user-invocable-only",
    "caveman:caveman-stats": "user-invocable-only",
    "product-management:roadmap-management": "user-invocable-only",
    "product-management:competitive-analysis": "user-invocable-only",
    "product-management:user-research-synthesis": "user-invocable-only",
    "product-management:metrics-tracking": "user-invocable-only",
    "product-management:stakeholder-comms": "user-invocable-only",
    "workflow:spec-metadata": "user-invocable-only",
    "shared:learnings-capturer": "user-invocable-only",
    "hookify:writing-rules": "user-invocable-only",
    "shared:roi-feedback-tracker": "user-invocable-only",
    "caveman:caveman-help": "user-invocable-only",
    "skill-audit": "user-invocable-only",
    "ws-atlassian:ws-atlassian": "user-invocable-only",
    "shared:framework-detector": "off",
    "shared:code-analyzer": "off",
    "shared:test-planner": "off"
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"${SUPACODE_SOCKET_PATH:-}\" ] && [ -n \"${SUPACODE_WORKTREE_ID:-}\" ] && [ -n \"${SUPACODE_TAB_ID:-}\" ] && [ -n \"${SUPACODE_SURFACE_ID:-}\" ] && { printf '%s claude\\n' \"$SUPACODE_WORKTREE_ID $SUPACODE_TAB_ID $SUPACODE_SURFACE_ID\"; cat; } | /usr/bin/nc -U -w1 \"$SUPACODE_SOCKET_PATH\" 2>/dev/null || true",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Read|Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/nono-hook.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"${SUPACODE_SOCKET_PATH:-}\" ] && [ -n \"${SUPACODE_WORKTREE_ID:-}\" ] && [ -n \"${SUPACODE_TAB_ID:-}\" ] && [ -n \"${SUPACODE_SURFACE_ID:-}\" ] && echo \"$SUPACODE_WORKTREE_ID $SUPACODE_TAB_ID $SUPACODE_SURFACE_ID 0\" | /usr/bin/nc -U -w1 \"$SUPACODE_SOCKET_PATH\" 2>/dev/null || true",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"/Users/trevor.smith/.wellsky-claude/hooks/pre-commit-claudemd-review.sh\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"${SUPACODE_SOCKET_PATH:-}\" ] && [ -n \"${SUPACODE_WORKTREE_ID:-}\" ] && [ -n \"${SUPACODE_TAB_ID:-}\" ] && [ -n \"${SUPACODE_SURFACE_ID:-}\" ] && echo \"$SUPACODE_WORKTREE_ID $SUPACODE_TAB_ID $SUPACODE_SURFACE_ID 0\" | /usr/bin/nc -U -w1 \"$SUPACODE_SOCKET_PATH\" 2>/dev/null || true",
            "timeout": 1
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"${SUPACODE_SOCKET_PATH:-}\" ] && [ -n \"${SUPACODE_WORKTREE_ID:-}\" ] && [ -n \"${SUPACODE_TAB_ID:-}\" ] && [ -n \"${SUPACODE_SURFACE_ID:-}\" ] && echo \"$SUPACODE_WORKTREE_ID $SUPACODE_TAB_ID $SUPACODE_SURFACE_ID 0\" | /usr/bin/nc -U -w1 \"$SUPACODE_SOCKET_PATH\" 2>/dev/null || true",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"${SUPACODE_SOCKET_PATH:-}\" ] && [ -n \"${SUPACODE_WORKTREE_ID:-}\" ] && [ -n \"${SUPACODE_TAB_ID:-}\" ] && [ -n \"${SUPACODE_SURFACE_ID:-}\" ] && { printf '%s claude\\n' \"$SUPACODE_WORKTREE_ID $SUPACODE_TAB_ID $SUPACODE_SURFACE_ID\"; cat; } | /usr/bin/nc -U -w1 \"$SUPACODE_SOCKET_PATH\" 2>/dev/null || true",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/caveman-reminder.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"${SUPACODE_SOCKET_PATH:-}\" ] && [ -n \"${SUPACODE_WORKTREE_ID:-}\" ] && [ -n \"${SUPACODE_TAB_ID:-}\" ] && [ -n \"${SUPACODE_SURFACE_ID:-}\" ] && echo \"$SUPACODE_WORKTREE_ID $SUPACODE_TAB_ID $SUPACODE_SURFACE_ID 1\" | /usr/bin/nc -U -w1 \"$SUPACODE_SOCKET_PATH\" 2>/dev/null || true",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true"
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "mise exec node@25 -- claude-powerline --theme=tokyo-night --style=powerline"
  },
  "enabledPlugins": {
    "architect@wellsky-plugins": true,
    "atlassian@claude-plugins-official": false,
    "bug-fix@wellsky-plugins": true,
    "caveman@caveman": true,
    "chrome-devtools-mcp@chrome-devtools-plugins": false,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": false,
    "hookify@claude-plugins-official": true,
    "iac-assistant@wellsky-plugins": false,
    "otel-telemetry@wellsky-plugins": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "product-management@wellsky-plugins": true,
    "ruby-lsp@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": true,
    "security-screener@wellsky-plugins": true,
    "shared@wellsky-plugins": true,
    "skill-creator@claude-plugins-official": true,
    "sourcegraph@claude-plugins-official": false,
    "superpowers@claude-plugins-official": true,
    "terraform-code-generation@hashicorp": false,
    "terraform-module-generation@hashicorp": false,
    "typescript-lsp@claude-plugins-official": false,
    "unit-gen@wellsky-plugins": true,
    "workflow@wellsky-plugins": true,
    "ws-atlassian@wellsky-plugins": true,
    "zapier@claude-plugins-official": false,
    "warp@claude-code-warp": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      },
      "autoUpdate": true
    },
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      },
      "autoUpdate": true
    },
    "dotnet-agent-skills": {
      "source": {
        "source": "github",
        "repo": "dotnet/skills"
      },
      "autoUpdate": true
    },
    "hashicorp": {
      "source": {
        "source": "github",
        "repo": "hashicorp/agent-skills"
      },
      "autoUpdate": true
    },
    "jfr992": {
      "source": {
        "source": "github",
        "repo": "jfr992/terragrunt-skill"
      },
      "autoUpdate": true
    },
    "terrashark": {
      "source": {
        "source": "github",
        "repo": "LukasNiessen/terrashark"
      },
      "autoUpdate": true
    },
    "wellsky-plugins": {
      "source": {
        "source": "git",
        "url": "git@github.com:mediwareinc/wellsky-claude-code-plugins.git",
        "ref": "fix/combined-skill-descriptions"
      }
    },
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
  "syntaxHighlightingDisabled": false,
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "tui": "fullscreen",
  "autoDreamEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vim",
  "preferredNotifChannel": "auto",
  "showTurnDuration": true,
  "skipAutoPermissionPrompt": true,
  "useAutoModeDuringPlan": false
}
