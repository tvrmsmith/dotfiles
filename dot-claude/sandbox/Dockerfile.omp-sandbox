# Stage 1: Build oh-my-pi from fork (arm64 glimmer fix)
FROM node:22-bookworm AS omp-builder
RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/root/.bun/bin:$PATH"
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain nightly-2026-03-27
ENV PATH="/root/.cargo/bin:$PATH"
RUN --mount=type=cache,target=/root/.bun/install/cache \
  --mount=type=cache,target=/root/.cargo/registry \
  --mount=type=cache,target=/root/.cargo/git \
  git clone --depth 1 --branch fix/glimmer-arm64-scanner https://github.com/tvrmsmith/oh-my-pi.git /opt/oh-my-pi && \
  cd /opt/oh-my-pi && bun install && bun run build:native && bun run install:dev

# Stage 2: Final sandbox image
FROM docker/sandbox-templates:shell-docker

USER root

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# mise
ENV MISE_DATA_DIR="/mise"
ENV MISE_CONFIG_DIR="/mise"
ENV MISE_CACHE_DIR="/mise/cache"
ENV MISE_INSTALL_PATH="/usr/local/bin/mise"
ENV PATH="/mise/shims:$PATH"
ENV MISE_TRUSTED_CONFIG_PATHS="/"
RUN curl https://mise.run | sh

# bun
ENV BUN_INSTALL="/opt/bun"
ENV PATH="/opt/bun/bin:$PATH"
RUN curl -fsSL https://bun.sh/install | bash

# System packages (gcloud, gh, openssh)
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
  --mount=type=cache,target=/var/lib/apt,sharing=locked \
  rm -f /etc/apt/apt.conf.d/docker-clean && \
  echo 'Binary::apt::APT::Keep-Downloaded-Packages "true";' > /etc/apt/apt.conf.d/keep-cache && \
  apt-get update && \
  apt-get install -y --no-install-recommends ca-certificates gnupg2 curl && \
  echo "deb [signed-by=/usr/share/keyrings/cloud.google.gpg] https://packages.cloud.google.com/apt cloud-sdk main" | \
  tee /etc/apt/sources.list.d/google-cloud-sdk.list && \
  curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg | \
  gpg --dearmor -o /usr/share/keyrings/cloud.google.gpg && \
  curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | \
  tee /usr/share/keyrings/githubcli-archive-keyring.gpg > /dev/null && \
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | \
  tee /etc/apt/sources.list.d/github-cli.list > /dev/null && \
  apt-get update && \
  apt-get install -y --no-install-recommends \
    gh \
    google-cloud-cli \
    lsb-release \
    openssh-client

# Signing key script (stable)
COPY setup-signing-key.sh /tmp/setup-signing-key.sh

# Oh My Pi — copy entire app from builder
COPY --from=omp-builder /opt/oh-my-pi /opt/oh-my-pi
RUN ln -s /opt/oh-my-pi/packages/coding-agent/src/cli.ts /usr/local/bin/omp && \
  ln -s /opt/oh-my-pi/packages/coding-agent/src/cli.ts /usr/local/bin/pi

# Anthropic Vertex extension
COPY --from=omp-vertex-ext . /opt/omp-extensions/anthropic-vertex/
RUN --mount=type=cache,target=/opt/bun/install/cache \
  cd /opt/omp-extensions/anthropic-vertex && bun install --production && \
  mkdir -p /home/agent/.omp/plugins/node_modules && \
  ln -s /opt/omp-extensions/anthropic-vertex /home/agent/.omp/plugins/node_modules/omp-extension-anthropic-vertex && \
  echo '{"name":"omp-plugins","private":true,"dependencies":{"omp-extension-anthropic-vertex":"file:node_modules/omp-extension-anthropic-vertex"}}' > /home/agent/.omp/plugins/package.json && \
  chown -R agent:agent /home/agent/.omp

ARG DOTFILES_SHA
# Dotfiles (cache busted by commit SHA)
RUN git clone https://github.com/tvrmsmith/dotfiles.git /home/agent/dotfiles && \
    /home/agent/dotfiles/install.sh

# SSH commit-signing key (uploaded to GitHub at build time)
ARG GIT_USER_NAME
ARG GIT_USER_EMAIL
USER agent
RUN --mount=type=secret,id=github_token,uid=1000 --mount=type=secret,id=github_token_personal,uid=1000 /tmp/setup-signing-key.sh
USER root
RUN rm /tmp/setup-signing-key.sh

# Build args last — only affect ENV, not tool installs above
ARG GOOGLE_CLOUD_PROJECT
ARG GOOGLE_CLOUD_LOCATION
ARG OMP_MODEL
ENV GOOGLE_CLOUD_PROJECT=${GOOGLE_CLOUD_PROJECT}
ENV GOOGLE_CLOUD_LOCATION=${GOOGLE_CLOUD_LOCATION}
ENV OMP_MODEL=${OMP_MODEL}

USER agent

# Shell integration and auto-launch
RUN echo 'eval "$(mise activate bash)"' >> /home/agent/.bashrc && \
  cat >> /home/agent/.bashrc << 'EOF'

# Auto-launch omp coding agent
if [[ $- == *i* ]] && command -v omp &> /dev/null; then
  exec omp --model "$OMP_MODEL"
fi
EOF
