# Sandbox image
FROM docker/sandbox-templates:shell-docker

USER root

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# mise
ENV MISE_DATA_DIR="/mise"
ENV MISE_CONFIG_DIR="/mise"
ENV MISE_CACHE_DIR="/mise/cache"
ENV MISE_INSTALL_PATH="/usr/local/bin/mise"
ENV PATH="/mise/shims:$PATH"
ENV MISE_TRUSTED_CONFIG_PATHS="/"
RUN install -d -o agent -g agent /mise /mise/cache && \
  curl https://mise.run | sh

# bun
ENV BUN_INSTALL="/opt/bun"
ENV PATH="/opt/bun/bin:$PATH"
RUN curl -fsSL https://bun.sh/install | bash

# System packages (gcloud, gh, openssh)
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
  --mount=type=cache,target=/var/lib/apt,sharing=locked \
  rm -f /etc/apt/apt.conf.d/docker-clean && \
  echo 'Binary::apt::APT::Keep-Downloaded-Packages "true";' > /etc/apt/apt.conf.d/keep-cache && \
  apt-get update && \
  apt-get install -y --no-install-recommends ca-certificates gnupg2 curl && \
  echo "deb [signed-by=/usr/share/keyrings/cloud.google.gpg] https://packages.cloud.google.com/apt cloud-sdk main" | \
  tee /etc/apt/sources.list.d/google-cloud-sdk.list && \
  curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg | \
  gpg --dearmor -o /usr/share/keyrings/cloud.google.gpg && \
  curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | \
  tee /usr/share/keyrings/githubcli-archive-keyring.gpg > /dev/null && \
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | \
  tee /etc/apt/sources.list.d/github-cli.list > /dev/null && \
  apt-get update && \
  apt-get install -y --no-install-recommends \
    gh \
    google-cloud-cli \
    lsb-release \
    openssh-client \
    stow \
    build-essential \
    pkg-config \
    libssl-dev

# Oh My Pi coding agent (installed globally via bun)
# OMP_VERSION is set from docker-compose.yml; bumping it busts only this layer
# downward, leaving the apt/gcloud layers above cached.
ARG OMP_VERSION=latest
RUN --mount=type=cache,target=/opt/bun/install/cache \
  bun install -g @oh-my-pi/pi-coding-agent@${OMP_VERSION} && \
  ln -s /opt/bun/bin/omp /usr/local/bin/pi

# Rust toolchain. Used by `dsbx-omp-build` (host-side helper) when it runs this
# image as a one-shot container to build packages/natives for linux-arm64 from
# the user's omp fork. Sandboxes themselves never invoke cargo — they consume
# the prebuilt tree via bind mount.
# rust-toolchain.toml in the fork pins the channel, so we install rustup with no
# default toolchain and let the workspace materialize the right nightly on first use.
ENV RUSTUP_HOME=/opt/rust/rustup
ENV CARGO_HOME=/opt/rust/cargo
ENV PATH="/opt/rust/cargo/bin:$PATH"
RUN install -d -o agent -g agent /opt/rust /opt/rust/rustup /opt/rust/cargo && \
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | \
    su agent -c 'sh -s -- -y --no-modify-path --default-toolchain none --profile minimal'

# OMP launcher shim, registered as the `claude` agent so `sbx run claude -t omp-sandbox`
# dispatches it directly via sbx's hardcoded agent table (no bashrc gymnastics, no
# `shell` agent + auto-launch race). sbx execs /usr/local/bin/claude with TTY; we exec omp.
# Args from sbx (e.g. --dangerously-skip-permissions) are discarded — they're claude-only.
RUN cat > /usr/local/bin/claude <<'SH' && chmod +x /usr/local/bin/claude
#!/usr/bin/env bash
# sbx injects ANTHROPIC_API_KEY=proxy-managed; OMP would treat that as a real key
# and skip the Vertex provider. Strip it before exec.
unset ANTHROPIC_API_KEY
# Prefer the host-built fork if dsbx-omp-build has produced one.
# ~/.omp-fork is a symlink to the bind-mounted host cache (~/.cache/dsbx-omp-fork);
# install-helper-links creates it unconditionally, so the existence check is on
# the cli.ts file (dangling symlink => fall through to published omp).
FORK_CLI="$HOME/.omp-fork/packages/coding-agent/src/cli.ts"
if [ -f "$FORK_CLI" ]; then
  exec bun "$FORK_CLI" --model "${OMP_MODEL}"
fi
exec omp --model "${OMP_MODEL}"
SH

# Anthropic Vertex extension (install to /opt, link after dotfiles stow)
COPY --from=omp-vertex-ext . /opt/omp-extensions/anthropic-vertex/
RUN --mount=type=cache,target=/opt/bun/install/cache \
  cd /opt/omp-extensions/anthropic-vertex && bun install --production

# OMP plugin link (independent of dotfiles — baked once). Run as root because
# the base image's /home/agent may not be agent-owned at this stage.
RUN install -d -o agent -g agent /home/agent/.omp /home/agent/.omp/plugins /home/agent/.omp/plugins/node_modules && \
  ln -s /opt/omp-extensions/anthropic-vertex /home/agent/.omp/plugins/node_modules/omp-extension-anthropic-vertex && \
  chown -h agent:agent /home/agent/.omp/plugins/node_modules/omp-extension-anthropic-vertex

# Allow git operations on bind-mounted volumes regardless of host uid. System
# scope (not --global) so it applies to the agent runtime user, and dodges
# the Docker Desktop /root-ownership-remap quirk that breaks --global writes.
RUN git config --system --add safe.directory '*'

# SSH commit signing uses the host 1Password agent forwarded by sbx (>=0.28):
# `ssh-add -L` inside the sandbox lists the host signing key. The stowed host
# dot-gitconfig provides the matching `signingkey` value, but its
# `gpg.ssh.program` points at the macOS 1Password helper. Override it via
# ~/.gitconfig.sandbox (already included by the host gitconfig) so signing
# uses the linux ssh-keygen. Pin allowedSignersFile to the stowed host file.
RUN install -d -o agent -g agent /home/agent && \
  printf '%s\n' \
    '[gpg "ssh"]' \
    '	program = /usr/bin/ssh-keygen' \
    '	allowedSignersFile = /home/agent/.ssh/allowed_signers' \
    > /home/agent/.gitconfig.sandbox && \
  chown agent:agent /home/agent/.gitconfig.sandbox

# Build args last — only affect ENV, not tool installs above
ARG GOOGLE_CLOUD_PROJECT
ARG GOOGLE_CLOUD_LOCATION
ARG OMP_MODEL
ENV GOOGLE_CLOUD_PROJECT=${GOOGLE_CLOUD_PROJECT}
ENV GOOGLE_CLOUD_LOCATION=${GOOGLE_CLOUD_LOCATION}
ENV OMP_MODEL=${OMP_MODEL}

# Stamp /home/agent ownership before USER agent. The host dotfiles tree is
# bind-mounted RO at runtime by `_dsbx_install_helper_links` and stowed into
# ~/, so shell rc files (.bashrc, .gitconfig) come from the host — nothing
# user-facing is baked here. Docker Desktop's containerd snapshotter
# intermittently remaps unstamped dir ownership to nobody:nogroup across
# layer transitions, leaving the runtime agent user unable to write its own
# home; re-stamping here pins ownership into the exported image.
RUN chown agent:agent /home/agent

USER agent
