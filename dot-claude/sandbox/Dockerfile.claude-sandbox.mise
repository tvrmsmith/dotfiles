FROM docker/sandbox-templates:claude-code-docker

USER root

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

# mise
ENV MISE_DATA_DIR="/mise"
ENV MISE_CONFIG_DIR="/mise"
ENV MISE_CACHE_DIR="/mise/cache"
ENV MISE_INSTALL_PATH="/usr/local/bin/mise"
ENV PATH="/mise/shims:$PATH"
ENV MISE_TRUSTED_CONFIG_PATHS="/"
RUN install -d -o agent -g agent /mise /mise/cache && \
  curl https://mise.run | sh

# System packages (gcloud, gh, openssh)
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
  --mount=type=cache,target=/var/lib/apt,sharing=locked \
  rm -f /etc/apt/apt.conf.d/docker-clean && \
  echo 'Binary::apt::APT::Keep-Downloaded-Packages "true";' > /etc/apt/apt.conf.d/keep-cache && \
  apt-get update && \
  apt-get install -y --no-install-recommends ca-certificates gnupg2 curl && \
  echo "deb [signed-by=/usr/share/keyrings/cloud.google.gpg] https://packages.cloud.google.com/apt cloud-sdk main" | \
  tee /etc/apt/sources.list.d/google-cloud-sdk.list && \
  curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg | \
  gpg --dearmor -o /usr/share/keyrings/cloud.google.gpg && \
  curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | \
  tee /usr/share/keyrings/githubcli-archive-keyring.gpg > /dev/null && \
  echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | \
  tee /etc/apt/sources.list.d/github-cli.list > /dev/null && \
  apt-get update && \
  apt-get install -y --no-install-recommends \
    gh \
    google-cloud-cli \
    lsb-release \
    openssh-client \
    stow

# Shell integration (mise activation, helper sources) lives in the host
# dot-bashrc, which is bind-mounted RO and stowed into ~/.bashrc by
# `_dsbx_install_helper_links`. The /mise/shims dir on PATH (set above) is
# enough for non-interactive `mise exec`; activate is the interactive sugar.
#
# SSH commit signing uses the host 1Password agent forwarded by sbx (>=0.28):
# `ssh-add -L` inside the sandbox lists the host signing key. The stowed host
# dot-gitconfig provides the matching `signingkey` value, but its
# `gpg.ssh.program` points at the macOS 1Password helper. Override it via
# ~/.gitconfig.sandbox (already included by the host gitconfig) so signing
# uses the linux ssh-keygen. Pin allowedSignersFile to the stowed host file.
RUN install -d -o agent -g agent /home/agent && \
  printf '%s\n' \
    '[gpg "ssh"]' \
    '	program = /usr/bin/ssh-keygen' \
    '	allowedSignersFile = /home/agent/.ssh/allowed_signers' \
    > /home/agent/.gitconfig.sandbox && \
  chown agent:agent /home/agent/.gitconfig.sandbox

# Build args last — only affect ENV, not tool installs above
ARG CLAUDE_CODE_USE_VERTEX
ARG CLOUD_ML_REGION
ARG ANTHROPIC_VERTEX_PROJECT_ID
ENV CLAUDE_CODE_USE_VERTEX=${CLAUDE_CODE_USE_VERTEX}
ENV CLOUD_ML_REGION=${CLOUD_ML_REGION}
ENV ANTHROPIC_VERTEX_PROJECT_ID=${ANTHROPIC_VERTEX_PROJECT_ID}
USER agent
