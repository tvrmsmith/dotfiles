#!/usr/bin/env bash
# Update vendored subtrees from upstream.
#
# Usage:
#   vendor/update                    # update all registered subtrees
#   vendor/update 1password-skill    # update one
#   vendor/update --list             # show registered subtrees
#
# To register a new subtree, add a line to SUBTREES below:
#   <prefix-under-vendor>|<remote-name>|<branch>|<upstream-url>
set -euo pipefail

# prefix|remote|branch|url
SUBTREES=(
  "1password-skill|petejm-1password|main|https://github.com/petejm/1password-skill.git"
)

# NPM-packaged single-file skills: the whole repo is not worth a subtree, the
# skill is one file shipped inside an npm package. prefix|package|version|subpath
# After fetch, every `npx -y <package>` in the file is rewritten to the bare
# binary so the vendored skill uses the pinned global install (see install.sh)
# instead of auto-fetching latest on every call. Bump the version here to update.
NPM_SKILLS=(
  "lavish-axi|lavish-axi|0.1.38|skills/lavish/SKILL.md"
)

# Git-hosted single-file skills: the skill is one file inside a large upstream
# git repo not worth a subtree (e.g. a Go CLI project). Fetch shallow and extract
# just the one blob via `git show` — no working-tree checkout, no repo bloat.
# prefix|remote|branch|subpath|url  (subpath is relative to the upstream repo root)
GIT_SKILLS=(
  "no-mistakes|kunchenguid-no-mistakes|main|skills/no-mistakes/SKILL.md|https://github.com/kunchenguid/no-mistakes.git"
)

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

ensure_remote() {
  local remote=$1 url=$2
  if ! git remote get-url "$remote" >/dev/null 2>&1; then
    echo "→ adding remote $remote → $url"
    git remote add "$remote" "$url"
  fi
}

require_clean_tree() {
  if ! git diff-index --quiet HEAD -- 2>/dev/null || \
     [ -n "$(git ls-files --others --exclude-standard)" ]; then
    echo "error: working tree has uncommitted changes; commit or stash first" >&2
    git status --short >&2
    exit 1
  fi
}

update_one() {
  local entry=$1
  IFS='|' read -r prefix remote branch url <<<"$entry"
  ensure_remote "$remote" "$url"
  echo "→ updating vendor/$prefix from $remote/$branch"
  git fetch --quiet "$remote" "$branch"
  git subtree pull --prefix="vendor/$prefix" "$remote" "$branch" --squash \
    -m "vendor: update $prefix from $remote/$branch"
}

fetch_npm_skill() {
  local entry=$1
  IFS='|' read -r prefix pkg version subpath <<<"$entry"
  local dest="vendor/$prefix/$subpath"
  echo "→ vendoring vendor/$prefix from npm $pkg@$version ($subpath)"
  local tmp
  tmp="$(mktemp -d)"
  if ! ( cd "$tmp" && npm pack "$pkg@$version" >/dev/null 2>&1 \
         && tar xzf "$pkg"-*.tgz ); then
    echo "error: npm pack $pkg@$version failed" >&2
    rm -rf "$tmp"; exit 1
  fi
  if [ ! -f "$tmp/package/$subpath" ]; then
    echo "error: $subpath not found in $pkg@$version" >&2
    rm -rf "$tmp"; exit 1
  fi
  mkdir -p "$(dirname "$dest")"
  cp "$tmp/package/$subpath" "$dest"
  rm -rf "$tmp"
  # Pin invocations to the local binary; never auto-fetch latest via npx -y.
  sed -i.bak "s/npx -y $pkg/$pkg/g" "$dest" && rm -f "$dest.bak"
}

fetch_git_skill() {
  local entry=$1
  IFS='|' read -r prefix remote branch subpath url <<<"$entry"
  ensure_remote "$remote" "$url"
  local dest="vendor/$prefix/$subpath"
  echo "→ vendoring vendor/$prefix from $remote/$branch ($subpath)"
  git fetch --quiet --depth 1 "$remote" "$branch"
  if ! git cat-file -e "$remote/$branch:$subpath" 2>/dev/null; then
    echo "error: $subpath not found in $remote/$branch" >&2
    exit 1
  fi
  mkdir -p "$(dirname "$dest")"
  git show "$remote/$branch:$subpath" > "$dest"
}

list() {
  printf "%-24s %-22s %-8s %s\n" PREFIX REMOTE BRANCH URL
  for e in "${SUBTREES[@]}"; do
    IFS='|' read -r prefix remote branch url <<<"$e"
    printf "%-24s %-22s %-8s %s\n" "$prefix" "$remote" "$branch" "$url"
  done
  printf "\n%-24s %-22s %-8s %s\n" PREFIX PACKAGE VERSION SUBPATH
  for e in "${NPM_SKILLS[@]}"; do
    IFS='|' read -r prefix pkg version subpath <<<"$e"
    printf "%-24s %-22s %-8s %s\n" "$prefix" "$pkg" "$version" "$subpath"
  done
  printf "\n%-24s %-22s %-8s %s\n" PREFIX REMOTE BRANCH SUBPATH
  for e in "${GIT_SKILLS[@]}"; do
    IFS='|' read -r prefix remote branch subpath url <<<"$e"
    printf "%-24s %-22s %-8s %s\n" "$prefix" "$remote" "$branch" "$subpath"
  done
}

if [[ ${1:-} == "--list" || ${1:-} == "-l" ]]; then
  list; exit 0
fi

if [[ $# -eq 0 ]]; then
  require_clean_tree
  for e in "${SUBTREES[@]}"; do update_one "$e"; done
  for e in "${NPM_SKILLS[@]}"; do fetch_npm_skill "$e"; done
  for e in "${GIT_SKILLS[@]}"; do fetch_git_skill "$e"; done
  exit 0
fi

target=$1
for e in "${SUBTREES[@]}"; do
  IFS='|' read -r prefix _ _ _ <<<"$e"
  if [[ "$prefix" == "$target" ]]; then
    require_clean_tree
    update_one "$e"; exit 0
  fi
done
for e in "${NPM_SKILLS[@]}"; do
  IFS='|' read -r prefix _ _ _ <<<"$e"
  if [[ "$prefix" == "$target" ]]; then
    require_clean_tree
    fetch_npm_skill "$e"; exit 0
  fi
done
for e in "${GIT_SKILLS[@]}"; do
  IFS='|' read -r prefix _ _ _ _ <<<"$e"
  if [[ "$prefix" == "$target" ]]; then
    require_clean_tree
    fetch_git_skill "$e"; exit 0
  fi
done

echo "error: no registered subtree named '$target'" >&2
echo "registered:" >&2
list >&2
exit 1
