#!/usr/bin/env bash
# op-ssh-sign — locate the 1Password SSH signing binary per platform and exec
# it. git's gpg.ssh.program needs a single fixed path, but that path differs
# by OS (and by package manager on Linux), so this wrapper resolves it at
# call time instead of hardcoding one path in dot-gitconfig.
set -euo pipefail

candidates=(
  "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
  "/opt/1Password/op-ssh-sign"
  "/usr/lib/1password/op-ssh-sign"
)

for bin in "${candidates[@]}"; do
  if [ -x "$bin" ]; then
    exec "$bin" "$@"
  fi
done

echo "op-ssh-sign: no 1Password SSH signing binary found (checked: ${candidates[*]})" >&2
exit 1
