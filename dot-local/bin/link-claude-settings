#!/usr/bin/env bash
#
# link-claude-settings.sh
#
# Symlinks personal Claude Code config in a git worktree back to the main
# repo's copy, so local settings + personal agent config survive worktree
# creation. Currently mirrors:
#   - .claude/settings.local.json   (Claude Code local settings)
#   - CLAUDE.local.md               (personal, gitignored Claude memory)
#   - docs/agents/                  (Matt Pocock skills config: issue tracker,
#                                     triage labels, domain docs)
#   - .claude/skills/imr/           (personal repo-scoped imr command skill)
#
# It also overwrites the tracked CLAUDE.md with a personal compressed copy
# (docs/agents/CLAUDE.compressed.md, git-excluded) when that copy exists, and
# marks CLAUDE.md skip-worktree so the overwrite never shows up in git status
# or gets committed.
#
# Usage:
#   - Run as a Superset post-create setup script, or
#   - Run manually inside any worktree: ./scripts/link-claude-settings.sh
#
# Safe to run repeatedly. In the main worktree it only applies the compressed
# CLAUDE.md (no symlinks to create there).

set -euo pipefail

# Paths (relative to repo root) to mirror from the main worktree.
LINK_PATHS=(
  ".claude/settings.local.json"
  "CLAUDE.local.md"
  "docs/agents"
  ".claude/skills/imr"
)

# Must be inside a git repo.
if ! git rev-parse --git-common-dir >/dev/null 2>&1; then
  echo "link-claude-settings: not a git repository, skipping." >&2
  exit 0
fi

# Main repo root = parent of the shared (common) git dir.
common_dir="$(git rev-parse --git-common-dir)"
# Resolve to an absolute path (common_dir may be relative).
main_root="$(cd "$(dirname "$common_dir")" && pwd)"
worktree_root="$(git rev-parse --show-toplevel)"

# Overwrite the tracked CLAUDE.md with the personal compressed copy, if present.
# Uses a real copy (not a symlink) + skip-worktree so the tree stays clean and
# the change is never staged/committed. Runs in BOTH the main worktree and
# linked worktrees (the compressed copy should apply everywhere).
overwrite_claude_md() {
  local rel="CLAUDE.md"
  local source_file="$main_root/docs/agents/CLAUDE.compressed.md"
  local target_file="$worktree_root/$rel"

  if [ ! -e "$source_file" ]; then
    echo "link-claude-settings: no compressed CLAUDE.md ($source_file), skipping overwrite." >&2
    return 0
  fi

  cp -f "$source_file" "$target_file"

  # Tell git to ignore local modifications to the tracked CLAUDE.md.
  if git -C "$worktree_root" ls-files --error-unmatch "$rel" >/dev/null 2>&1; then
    git -C "$worktree_root" update-index --skip-worktree "$rel" 2>/dev/null || true
  fi

  echo "link-claude-settings: overwrote $target_file with compressed copy (skip-worktree)"
}

overwrite_claude_md

# Symlinks are worktree-only; in the main worktree there is nothing to link.
if [ "$main_root" = "$worktree_root" ]; then
  echo "link-claude-settings: in main worktree, CLAUDE.md applied; nothing to link." >&2
  exit 0
fi

link_path() {
  local rel="$1"
  local source_file="$main_root/$rel"
  local target_file="$worktree_root/$rel"

  # Seed an empty settings file so its symlink is never dangling.
  if [ "$rel" = ".claude/settings.local.json" ] && [ ! -e "$source_file" ]; then
    mkdir -p "$(dirname "$source_file")"
    echo '{}' > "$source_file"
  fi

  # Skip anything that doesn't exist in the main worktree.
  if [ ! -e "$source_file" ]; then
    echo "link-claude-settings: $rel not present in main worktree, skipping." >&2
    return 0
  fi

  # Create/refresh the symlink. -f replace, -n don't descend into existing symlink dir.
  mkdir -p "$(dirname "$target_file")"
  ln -sfn "$source_file" "$target_file"
  echo "link-claude-settings: linked $target_file -> $source_file"
}

for rel in "${LINK_PATHS[@]}"; do
  link_path "$rel"
done
