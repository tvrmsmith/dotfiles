#!/usr/bin/env bash
#
# nm-claude
#
# Claude shim for the no-mistakes gate. no-mistakes clones each gated repo into
# its own managed bare repo and runs the pipeline in ephemeral worktrees, which
# therefore lack the personal, gitignored Claude config (CLAUDE.local.md,
# docs/agents/, CONTEXT.md, ...). This shim links that config into the current
# worktree before handing off to the real claude binary, so the gate agent sees
# the same personal setup as an interactive session.
#
# Wire it up in ~/.no-mistakes/config.yaml (global-only):
#   agent_path_override:
#     claude: /Users/trevor.smith/.local/bin/nm-claude
#
# The override is GLOBAL, so this runs for EVERY repo no-mistakes gates. It only
# links for repos that need it (matched by remote); everything else is a
# transparent pass-through to real claude.

set -uo pipefail

REAL_CLAUDE="/Users/trevor.smith/.local/bin/claude"
LINK_SETTINGS="/Users/trevor.smith/.local/bin/link-claude-settings"

# Map a git remote URL to the real dev checkout whose personal config should be
# linked into the gate worktree. Add cases here as more repos need it.
main_root_for_remote() {
  case "$1" in
    *Meridian.IMR*) printf '%s' "/Users/trevor.smith/dev/wellsky/Meridian.IMR" ;;
    *) return 1 ;;
  esac
}

# no-mistakes runs us with cwd = the ephemeral worktree.
if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  remote="$(git remote get-url origin 2>/dev/null || true)"
  if main_root="$(main_root_for_remote "$remote")" && [ -d "$main_root" ]; then
    # NM_SKIP_CLAUDE_MD: don't perturb the gate's diffing with the CLAUDE.md
    # overwrite. Best-effort — never let linking failure block the run.
    MAIN_ROOT="$main_root" NM_SKIP_CLAUDE_MD=1 "$LINK_SETTINGS" || true

    # Append gate-only review guidance into the gate worktree's CLAUDE.local.md.
    # link-claude-settings symlinks CLAUDE.local.md back to the real dev checkout;
    # here we replace that symlink with a real file = personal CLAUDE.local.md +
    # docs/agents/gate-guidance.md, so gate step agents (review/test/document/lint)
    # load the guidance without it touching the tracked CLAUDE.md/AGENTS.md or the
    # personal CLAUDE.local.md. CLAUDE.local.md is already in info/exclude, so the
    # materialized file never lands in the diff or PR. Best-effort; never blocks.
    guidance="$main_root/docs/agents/no-mistakes-gate-guidance.md"
    if [ -s "$guidance" ]; then
      worktree_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
      if [ -n "$worktree_root" ]; then
        target="$worktree_root/CLAUDE.local.md"
        src_local="$main_root/CLAUDE.local.md"
        tmp="$target.nm-tmp.$$"
        {
          [ -e "$src_local" ] && cat "$src_local" && printf '\n'
          cat "$guidance"
        } > "$tmp" 2>/dev/null && { rm -f "$target"; mv -f "$tmp" "$target"; } || rm -f "$tmp"
      fi
    fi
  fi
fi

exec "$REAL_CLAUDE" "$@"
