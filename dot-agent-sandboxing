# Docker Sandbox (sbx) — custom templates
_SBX_DIR="$HOME/dotfiles/dot-claude/sandbox"
_DSBX_AUTH_DIR="$HOME/.cache/dsbx-auth"
_DSBX_ADC_TTL=21600  # 6 hours in seconds

dsbx-build() {
  docker compose -f "$_SBX_DIR/docker-compose.yml" build "$@" && \
  for img in $(docker compose -f "$_SBX_DIR/docker-compose.yml" config --images); do
    echo "Loading $img into sbx..." && \
    docker save "$img" | sbx template load /dev/stdin
  done
}

_dsbx_needs_auth() {
  local ts_file="$_DSBX_AUTH_DIR/$1"
  [ -f "$ts_file" ] || return 0
  local mtime age
  mtime=$(stat -f %m "$ts_file" 2>/dev/null) || return 0
  age=$(( $(date +%s) - mtime ))
  [ $age -ge $_DSBX_ADC_TTL ]
}

_dsbx_mark_authed() {
  mkdir -p "$_DSBX_AUTH_DIR"
  touch "$_DSBX_AUTH_DIR/$1"
}

# Detect git worktree and return additional workspace paths needed for git access.
_dsbx_worktree_args() {
  local git_common_dir source_repo
  git_common_dir="$(git rev-parse --git-common-dir 2>/dev/null)" || return
  source_repo="$(cd "$git_common_dir/.." && pwd)"
  [[ "$source_repo" != "$(pwd)" ]] || return
  echo "$source_repo"
}

# Helper: create with template on first run, reconnect on subsequent runs
# Auto-detects git worktrees and mounts the source repo for git access.
_dsbx_run() {
  local template="$1" agent="$2" prefix="$3"
  shift 3
  local worktree_ws
  worktree_ws="$(_dsbx_worktree_args)"
  local -a extra_ws=("$@")
  [[ -n "$worktree_ws" ]] && extra_ws+=("$worktree_ws")
  local name="${prefix}-$(basename "$(pwd)")"
  for ws in "${extra_ws[@]}"; do
    name="${name}--$(basename "${ws%:ro}")"
  done
  if ! sbx ls 2>/dev/null | awk '{print $1}' | grep -qx "$name"; then
    sbx create -t "$template" --name "$name" "$agent" . "${extra_ws[@]}" || return 1
  fi
  if _dsbx_needs_auth "$name"; then
    if ! sbx exec "$name" -- gcloud auth application-default print-access-token &>/dev/null; then
      sbx exec -it "$name" -- gcloud auth application-default login --no-launch-browser || return 1
    fi
    _dsbx_mark_authed "$name"
  fi
  sbx run "$name"
}

dsbx-cc() { _dsbx_run claude-sandbox-mise:latest claude dsbx-cc "$@"; }
dsbx-ruby-cc() { _dsbx_run claude-sandbox-ruby-2.6.10:latest claude dsbx-ruby-cc "$@"; }
dsbx-omp() { _dsbx_run omp-sandbox:latest shell dsbx-omp "$@"; }

_dsbx_exec() {
  local prefix="$1"
  shift
  local name="${prefix}-$(basename "$(pwd)")"
  sbx exec -it "$name" -- "$@"
}

dsbx-gauth() {
  local prefix="${1:-dsbx-omp}"
  local name="${prefix}-$(basename "$(pwd)")"
  _dsbx_exec "$prefix" gcloud auth application-default login --no-launch-browser && \
    _dsbx_mark_authed "$name"
}
