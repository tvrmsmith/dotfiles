# Docker Sandbox (sbx) — custom templates
_SBX_DIR="$HOME/dotfiles/dot-claude/sandbox"
dsbx-build() {
  docker compose -f "$_SBX_DIR/docker-compose.yml" build "$@" && \
  for img in $(docker compose -f "$_SBX_DIR/docker-compose.yml" config --images); do
    echo "Loading $img into sbx..." && \
    docker save "$img" | sbx template load /dev/stdin
  done
}
# Helper: create with template on first run, reconnect on subsequent runs
_dsbx_run() {
  local template="$1" agent="$2" prefix="$3"
  shift 3
  local name="${prefix}-$(basename "$(pwd)")"
  if sbx ls 2>/dev/null | awk '{print $1}' | grep -qx "$name"; then
    sbx run "$name" "$@"
  else
    sbx run -t "$template" --name "$name" "$agent" . "$@"
  fi
}
dsbx-cc() { _dsbx_run claude-sandbox-mise:latest claude dsbx-cc "$@"; }
dsbx-ruby-cc() { _dsbx_run claude-sandbox-ruby-2.6.10:latest claude dsbx-ruby-cc "$@"; }
dsbx-omp() { _dsbx_run omp-sandbox:latest shell dsbx-omp "$@"; }
_dsbx_exec() {
  local prefix="$1"
  shift
  local name="${prefix}-$(basename "$(pwd)")"
  sbx exec -it "$name" -- "$@"
}
dsbx-gauth() { _dsbx_exec "${1:-dsbx-omp}" gcloud auth application-default login --no-launch-browser; }

