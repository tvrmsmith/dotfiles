# Reset terminal after a TUI crash leaves stdin raw + Kitty kbd protocol active.
# Disables: bracketed paste, mode 2031, kitty kb stack, modifyOtherKeys; shows cursor; restores cooked tty.
alias unwedge='printf "\e[?2004l\e[?2031l\e[<u\e[>4;0m\e[?25h"; stty sane'

# Superset spoofs TERM_PROGRAM=kitty so claude-code parses CSI-u, but xterm.js
# can't render Kitty graphics APC, so OMP's image-protocol writes leak as
# gibberish during every spinner redraw. Disable OMP image protocol + OSC
# notifications when the parent PTY is a Superset terminal.
if [ -n "$SUPERSET_TERMINAL_ID" ]; then
  export PI_FORCE_IMAGE_PROTOCOL=off
  export PI_NOTIFICATIONS=off
fi

# Vertex env prefix shared by pi/omp and nono-omp-*
_OMP_VERTEX="GOOGLE_CLOUD_PROJECT=$ANTHROPIC_VERTEX_PROJECT_ID GOOGLE_CLOUD_LOCATION=$CLOUD_ML_REGION"
alias pi="$_OMP_VERTEX command pi --model $OMP_MODEL"
omp() {
  case "$1" in
    agents|commit|config|grep|grievances|jupyter|plugin|read|search|setup|shell|ssh|stats|update|--help|-h|--version)
      env ${=_OMP_VERTEX} command omp "$@"
      ;;
    *)
      env ${=_OMP_VERTEX} command omp --model $OMP_MODEL "$@"
      ;;
  esac
}

