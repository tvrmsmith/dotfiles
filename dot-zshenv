export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_STATE_HOME="$HOME/.local/state"
export XDG_CACHE_HOME="$HOME/.cache"
export EZA_CONFIG_DIR="$XDG_DATA_HOME/eza"

export DEV_PERSONAL="$HOME/dev/personal"

export GIT_TOKEN="op://Employee/GitHub Personal Access Token/token"
export PATH="$HOME/.local/bin:$HOME/.dotnet/tools:$DEV_PERSONAL/ralph/scripts:$PATH"

# Vertex config for Claude Code lives in ~/.claude/settings.json (global default)
# and per-repo .claude/settings.local.json overrides. Not exported here so the
# global env does not shadow per-repo project selection. pi/omp set their own
# GOOGLE_CLOUD_PROJECT/LOCATION inline (see _OMP_VERTEX in .zshrc).
# NOTE: do NOT export GOOGLE_APPLICATION_CREDENTIALS to the default ADC path —
# google-auth-library finds that path automatically, and setting it makes
# `gcloud auth application-default login` prompt for confirmation every run.
export OMP_MODEL="anthropic-vertex/claude-opus-4-7"
export ENABLE_LSP_TOOL=1
export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

export NVM_DIR="$HOME/.nvm"

export POWERLINE_NERD_FONTS=1
export NVIM_APPNAME="nvim-LazyVim"
export EDITOR="vim"
export VISUAL="nvim"

# Bat setting
export BAT_THEME=""
export BAT_THEME_LIGHT="tokyonight_day"
export BAT_THEME_DARK="tokyonight_night"
export BAT_STYLE="full,-grid,-header-filesize,-header-filename"

# Atlassian (used by ws-atlassian skill and acli)
export JIRA_USERNAME="trevor.smith@wellsky.com"
export JIRA_BASE_URL="https://wellsky.atlassian.net"
export JIRA_API_TOKEN="op://Employee/JIRA CLI Token/credential"

# Route SSH agent traffic through 1Password so sandboxes (and any non-interactive
# shell) see the same keys ssh(1) uses via IdentityAgent in ~/.ssh/config.
# macOS default SSH_AUTH_SOCK points at an empty launchd agent.
_ONEP_SSH_SOCK="$HOME/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
[ -S "$_ONEP_SSH_SOCK" ] && export SSH_AUTH_SOCK="$_ONEP_SSH_SOCK"
unset _ONEP_SSH_SOCK

# OMP's "bash" tool isn't /bin/bash — it's brush-core, an in-process Rust shell
# that doesn't honor BASH_ENV. The native shell does honor PI_SHELL_PREFIX,
# which prepends to every tool command (see pi-utils/procmgr.ts:getShellPrefix
# and pi-coding-agent/src/exec/bash-executor.ts). We use it to source our
# wrapper file, which scope-guards on OMPCODE=1 and registers a `bunx` wrapper
# that strips CI for `bunx sherif` (sherif --fix refuses to run when CI is set,
# and OMP injects CI=1 unconditionally via NON_INTERACTIVE_ENV).
export PI_SHELL_PREFIX="source $HOME/.omp/bash-env.sh;"


LOCAL="$HOME/.zshenv.local"
[ -f "$LOCAL" ] && source "$LOCAL"
